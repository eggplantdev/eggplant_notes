# Capture the refs git is about to push (stdin) BEFORE any command can consume it.
# Per line: <local ref> <local sha> <remote ref> <remote sha>. The remote ref is
# the destination branch — that's how we differentiate a prod push (main) from a
# preview/feature push, before anything reaches the remote.
PROD_BRANCH=main
push_to_prod= sha_from= sha_to=
while read -r _local_ref local_sha remote_ref remote_sha; do
  if [ "$remote_ref" = "refs/heads/$PROD_BRANCH" ]; then
    push_to_prod=1; sha_from=$remote_sha; sha_to=$local_sha
  fi
done

# Prod-migrate guard (supabase-prod-migrate skill): the HUMAN gate. Only on a push
# to main that ships new supabase/migrations/, ASK up front (before the test wait)
# whether to apply them to prod. Decline → a SECOND prompt confirms you really want
# to ship code against the current (un-migrated) prod schema; "no" aborts the push
# now, before tests even run. We only record the decision here and ACT on it after
# tests pass (below) — so a test failure can never leave prod migrated but the code
# un-deployed (schema ahead of code). Both prompts read /dev/tty (stdin holds the
# ref list). This is a human convenience gate — agent enforcement is the global
# PreToolUse hook, which blocks the agent's `git push` before this runs. No tty
# (CI) → code-only.
do_migrate=
if [ -n "$push_to_prod" ]; then
  if [ "$sha_from" = "0000000000000000000000000000000000000000" ]; then
    sha_from=$(git hash-object -t tree /dev/null)   # new branch: diff vs empty tree
  fi
  # --diff-filter=A: only ADDED migration files are pending applies. Without it a
  # rename/edit or a *deletion* of a migration (e.g. removing a smoke-test file)
  # trips the guard as a false positive — git diff reports D/M lines too, and a
  # removed file is never something prod needs to migrate.
  if git diff --name-only --diff-filter=A "$sha_from" "$sha_to" -- supabase/migrations/ | grep -q .; then
    if { : < /dev/tty; } 2>/dev/null; then
      printf '\n⚠  Push to %s includes new supabase/migrations/.\n   Migrate the PROD database now (backup-first)? [y/N] ' "$PROD_BRANCH" > /dev/tty
      read -r reply < /dev/tty || reply=n
      case "$reply" in
        [Yy]*) do_migrate=1 ;;
        *)
          printf '   Migration declined. Push code to %s ANYWAY (deploys against the current prod schema)? [y/N] ' "$PROD_BRANCH" > /dev/tty
          read -r go < /dev/tty || go=n
          case "$go" in
            [Yy]*) echo "→ will push code only; prod schema unchanged" >&2 ;;
            *)     echo "✗ aborted — neither migrated nor pushed" >&2; exit 1 ;;
          esac
          ;;
      esac
    else
      echo "→ no terminal to confirm migration; deploying code only" >&2
    fi
  fi
fi

pnpm run typecheck
pnpm exec vitest run

# Act on the migrate decision only now — after tests pass — so we never migrate
# prod and then abort the push on a test failure.
if [ -n "$do_migrate" ]; then
  echo "→ migrating prod (pnpm db:push:safe)…" >&2
  pnpm db:push:safe < /dev/tty || { echo "✗ migration failed — aborting push" >&2; exit 1; }
fi

# Background watcher: prints Vercel deployment state transitions to this terminal.
# Detached subshell so `git push` returns immediately when the hook exits.
# DEPLOY_SHA pins the watcher to THIS commit's deploy (matched by SHA), not "newest".
# Set SKIP_WATCH_DEPLOY=1 to bypass (CI machines, offline pushes, etc.).
#
# Foreground auth precheck FIRST (~1s): a dead local CLI token can't watch
# deploys, and a backgrounded watcher would just poll blind and then misblame the
# Git integration 3 min later. Surface it loudly here instead. Non-fatal — never
# block a push over LOCAL auth; just skip the (useless) watcher.
if [ -z "${SKIP_WATCH_DEPLOY:-}" ]; then
  if bash scripts/watch-deploy.sh --check-auth; then
    ( DEPLOY_SHA="$(git rev-parse HEAD)" bash scripts/watch-deploy.sh & )
  else
    echo "  🔒 vercel: skipping deploy watcher — fix local CLI auth (see above), then push again to tail." >&2
  fi
fi
