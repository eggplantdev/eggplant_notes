# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/.next-e2e/
/.next-prodtest/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# pnpm content-addressable store (local cache, never commit)
.pnpm-store/

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# playwright mcp scratch output (snapshots, console logs, ad-hoc screenshots)
.playwright-mcp/

# playwright e2e artifacts
/test-results/
/playwright-report/
e2e/.auth/

# typescript
*.tsbuildinfo
next-env.d.ts
.env*.local

# personal machine notes (not project docs)
/docs/homebrew-arm-migration.md

# 10x-cli skills — installed globally (~/.claude/skills); re-fetched per-project by `10x get`, not committed
/.claude/skills/

# 10xDevs course lesson sources — copyrighted course material, re-fetched per-project by `10x get`, not committed
/lessons/

# Git worktrees (isolated per-change workspaces, e.g. via EnterWorktree); never committed
/.claude/worktrees/

.superpowers/

# Personal idea/TODO scratchpad — local only, never committed to the public repo
/.notes
